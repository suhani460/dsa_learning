import java.util.Arrays;
import java.util.Scanner;

public class Main{
    public static void main(String[] args) {
        // array input
        Scanner in = new Scanner(System.in);
        // array of premtive
         int[] arr = new int[5];
         arr[0]=45;
         arr[1]= 67;
         arr[2]= 78;
         arr[3]= 79;
         arr[4]= 688;
         System.out.println(arr[4]);


         //for loop we are taking input from user
        for(int i = 0; i< arr.length; i++) {
            arr[i] = in.nextInt();
        }
        // this  is the easiest way to print
        System.out.println(Arrays.toString(arr));

        // for loop we are printing user input
         for(int i = 0; i< arr.length; i++) {
            System.out.println(arr[i] +" ");
        }
         // this is also use to print your array
      for (int num: arr) {
          System.out.println(num + "");
     }


        }


     }
